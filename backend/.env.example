# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth
AUTH_SECRET=your-long-random-secret

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
